# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# --- Reach Out — at least ONE provider (see ENVIRONMENT.md) ---
# Easiest without Clay: Hunter.io Domain Search (free tier with monthly limits)
# https://hunter.io/api-documentation#domain-search
HUNTER_API_KEY=

# Optional: Happenstance — search YOUR professional network (connections/groups) for
# people matching the company; async (~30–60s). Key from https://happenstance.ai/api/keys
# Docs: https://developer.happenstance.ai/quickstart
# HAPPENSTANCE_API_KEY=
# HAPPENSTANCE_INCLUDE_FRIENDS_CONNECTIONS=true
# HAPPENSTANCE_POLL_MS=4000
# HAPPENSTANCE_MAX_WAIT_MS=55000

# Optional: Apollo people search (many free keys cannot use mixed_people search)
# APOLLO_API_KEY=

# Optional: Clay table webhook (may require paid Clay credits)
# CLAY_WEBHOOK_URL=https://app.clay.com/webhook/YOUR_WEBHOOK_ID
# CLAY_API_KEY=

# Optional: provider order — e.g. hunter,happenstance,apollo,clay
# REACH_OUT_PROVIDERS=hunter,happenstance,apollo,clay

# Optional: max people shown on Reach Out (default 5; keeps Hunter free tier happy)
RECRUITER_MAX_RESULTS=10

# --- Auth (Google / NextAuth) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_URL=http://localhost:3000   # local — production: https://your-domain.com (no trailing slash)
# In Google Cloud → OAuth client → Authorized redirect URIs, add exactly:
#   https://your-domain.com/api/auth/callback/google
# (Error 400 redirect_uri_mismatch = this URI or NEXTAUTH_URL does not match.)
# NEXTAUTH_SECRET=

# --- Supabase ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# (anon key if used client-side)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional: Gmail / OpenAI / Stripe (see your existing .env.local) ---
# OWNER_EMAILS=

# --- Admin panel (/admin) — comma-separated emails that may access admin APIs & pages
# (merged with OWNER_EMAILS for access). Google sign-in or /admin/login credentials.
ADMIN_EMAILS=jinank.thakker@gmail.com

# Optional: password login at /admin/login (set password to enable; do not use a weak password in production)
# ADMIN_CREDENTIALS_USER=admin
# ADMIN_CREDENTIALS_PASSWORD=admin123
# Session email shown for credential logins (defaults to jinank.thakker@gmail.com)
# ADMIN_SESSION_EMAIL=jinank.thakker@gmail.com
